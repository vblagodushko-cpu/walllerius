rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthed() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthed() && request.auth.token.admin == true;
    }

    // Фото товарів: artifacts/{appId}/products/{productDocId}/main.webp | thumb.webp
    match /artifacts/{appId}/products/{productDocId}/{fileName} {
      allow read: if isAuthed();
      allow write: if isAdmin()
        && (fileName == 'main.webp' || fileName == 'thumb.webp')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }
  }
}
